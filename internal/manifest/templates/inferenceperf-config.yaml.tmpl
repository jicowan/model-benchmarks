server:
  type: vllm
  model_name: {{ if .ModelName }}{{ .ModelName }}{{ else }}{{ .ModelHfID }}{{ end }}
  base_url: http://{{ .TargetHost }}:{{ .TargetPort }}
  ignore_eos: true

tokenizer:
  pretrained_model_name_or_path: {{ .ModelHfID }}

api:
  type: {{ .APIType }}
  streaming: {{ .Streaming }}

data:
  type: {{ .DatasetType }}
  input_distribution:
    mean: {{ .InputMean }}
    std_dev: {{ .InputStdDev }}
    min: {{ .InputMin }}
    max: {{ .InputMax }}
  output_distribution:
    mean: {{ .OutputMean }}
    std_dev: {{ .OutputStdDev }}
    min: {{ .OutputMin }}
    max: {{ .OutputMax }}

load:
  type: {{ .LoadType }}
  stages:
{{- range .Stages }}
    - rate: {{ .Rate }}
      duration: {{ .Duration }}
{{- end }}
  num_workers: {{ .NumWorkers }}

storage:
{{- if .StorageBucket }}
  # inference-perf's SimpleStorageServiceConfig in v0.2.0 accepts
  # {bucket_name, path, report_file_prefix}. Region resolution relies
  # on boto3's standard chain, which picks up AWS_REGION from the
  # pod env set in the loadgen Job template. PR #458 (unmerged as of
  # v0.2.0) adds optional region_name/endpoint_url/addressing_style;
  # if we bump to a release that includes it, we can wire those here.
  simple_storage_service:
    bucket_name: {{ .StorageBucket }}
    path: {{ .StoragePath }}
    report_file_prefix: {{ .StorageReportPrefix }}
{{- else }}
  local_storage:
    path: /tmp/results
{{- end }}

apiVersion: batch/v1
kind: Job
metadata:
  name: {{ .Name }}
  namespace: {{ .Namespace }}
  labels:
    app.kubernetes.io/name: {{ .Name }}
    app.kubernetes.io/component: loadgen
    accelbench/role: loadgen
spec:
  backoffLimit: 0
  ttlSecondsAfterFinished: 600
  template:
    metadata:
      labels:
        app.kubernetes.io/name: {{ .Name }}
        app.kubernetes.io/component: loadgen
        accelbench/role: loadgen
    spec:
      serviceAccountName: accelbench-loadgen
      restartPolicy: Never
      # PRD-53: our Karpenter NodePools carry an accelbench.io/dedicated
      # taint so AccelBench pods only land on our nodes and operator
      # pods never land here. Matching toleration required.
      tolerations:
        - key: accelbench.io/dedicated
          operator: Equal
          value: "true"
          effect: NoSchedule
      affinity:
        nodeAffinity:
          requiredDuringSchedulingIgnoredDuringExecution:
            nodeSelectorTerms:
              - matchExpressions:
                  - key: accelbench/node-type
                    operator: In
                    values:
                      - system
      containers:
        # Main benchmark container - official inference-perf image.
        # Results are written directly to S3 from inside inference-perf
        # via its native simple_storage_service integration; the
        # ServiceAccount (accelbench-loadgen) has a Pod Identity
        # association that grants s3:PutObject on the results bucket.
        - name: inference-perf
          image: {{ .InferencePerfImage }}
          command: ["inference-perf"]
          args: ["--config_file", "/workspace/config.yml"]
          env:
{{- if .HfToken }}
            - name: HF_TOKEN
              value: "{{ .HfToken }}"
{{- end }}
{{- if .AWSRegion }}
            - name: AWS_REGION
              value: "{{ .AWSRegion }}"
            - name: AWS_DEFAULT_REGION
              value: "{{ .AWSRegion }}"
{{- end }}
          volumeMounts:
            - name: config
              mountPath: /workspace/config.yml
              subPath: config.yml
            - name: results
              mountPath: /tmp/results
          resources:
            requests:
              cpu: "{{ if .CPURequest }}{{ .CPURequest }}{{ else }}2{{ end }}"
              memory: "{{ if .MemoryRequest }}{{ .MemoryRequest }}{{ else }}4Gi{{ end }}"
            limits:
              cpu: "{{ if .CPULimit }}{{ .CPULimit }}{{ else }}4{{ end }}"
              memory: "{{ if .MemoryLimit }}{{ .MemoryLimit }}{{ else }}8Gi{{ end }}"
      volumes:
        - name: config
          configMap:
            name: {{ .ConfigMapName }}
        # Scratch space for inference-perf's intermediate files. It still
        # writes to a local path internally even when uploading to S3;
        # keeping this mount avoids surprises on that code path.
        - name: results
          emptyDir: {}

apiVersion: batch/v1
kind: Job
metadata:
  name: {{ .Name }}
  namespace: {{ .Namespace }}
  labels:
    app.kubernetes.io/name: {{ .Name }}
    app.kubernetes.io/component: loadgen
    accelbench/role: loadgen
spec:
  backoffLimit: 0
  ttlSecondsAfterFinished: 600
  template:
    metadata:
      labels:
        app.kubernetes.io/name: {{ .Name }}
        app.kubernetes.io/component: loadgen
        accelbench/role: loadgen
    spec:
      serviceAccountName: accelbench-loadgen
      restartPolicy: Never
      affinity:
        nodeAffinity:
          requiredDuringSchedulingIgnoredDuringExecution:
            nodeSelectorTerms:
              - matchExpressions:
                  - key: accelbench/node-type
                    operator: In
                    values:
                      - system
      containers:
        # Main benchmark container - official inference-perf image
        - name: inference-perf
          image: {{ .InferencePerfImage }}
          command: ["inference-perf"]
          args: ["--config_file", "/workspace/config.yml"]
          env:
{{- if .HfToken }}
            - name: HF_TOKEN
              value: "{{ .HfToken }}"
{{- end }}
          volumeMounts:
            - name: config
              mountPath: /workspace/config.yml
              subPath: config.yml
            - name: results
              mountPath: /tmp/results
          resources:
            requests:
              cpu: "2"
              memory: "4Gi"
            limits:
              cpu: "4"
              memory: "8Gi"
{{- if .ResultsS3Bucket }}
        # Sidecar for S3 upload - waits for results, uploads, exits
        - name: s3-upload
          image: amazon/aws-cli:latest
          command: ["/bin/sh", "-c"]
          args:
            - |
              echo "Waiting for benchmark to complete..."
              # Wait for inference-perf to write results (check for any JSON file)
              while [ -z "$(ls /tmp/results/*.json 2>/dev/null)" ]; do
                sleep 5
              done
              # Give it a moment to finish writing
              sleep 2
              echo "Uploading results to S3..."
              # Find and upload the results file
              for f in /tmp/results/*.json; do
                aws s3 cp "$f" "s3://{{ .ResultsS3Bucket }}/{{ .ResultsS3Key }}"
                echo "Uploaded $f to s3://{{ .ResultsS3Bucket }}/{{ .ResultsS3Key }}"
              done
              echo "Upload complete"
          volumeMounts:
            - name: results
              mountPath: /tmp/results
          env:
            - name: AWS_REGION
              value: "{{ .AWSRegion }}"
          resources:
            requests:
              cpu: "100m"
              memory: "256Mi"
            limits:
              cpu: "500m"
              memory: "512Mi"
{{- end }}
      volumes:
        - name: config
          configMap:
            name: {{ .ConfigMapName }}
        - name: results
          emptyDir: {}

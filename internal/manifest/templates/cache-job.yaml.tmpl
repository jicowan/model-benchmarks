apiVersion: batch/v1
kind: Job
metadata:
  name: {{ .Name }}
  namespace: {{ .Namespace }}
  labels:
    app.kubernetes.io/name: {{ .Name }}
    app.kubernetes.io/component: cache-job
    accelbench/role: cache-job
    accelbench/cache-id: "{{ .CacheID }}"
spec:
  backoffLimit: 1
  ttlSecondsAfterFinished: 3600
  template:
    metadata:
      labels:
        app.kubernetes.io/name: {{ .Name }}
        app.kubernetes.io/component: cache-job
        accelbench/role: cache-job
    spec:
      serviceAccountName: accelbench-cache-job
      restartPolicy: Never
      affinity:
        nodeAffinity:
          requiredDuringSchedulingIgnoredDuringExecution:
            nodeSelectorTerms:
              - matchExpressions:
                  - key: accelbench/node-type
                    operator: In
                    values:
                      - system
      containers:
        - name: cache
          image: {{ .CacheImage }}
          # Streams each file from HF straight to S3 via multipart upload.
          # Only ~8 MiB is held in memory at a time; no local disk is used
          # for model weights.
          args:
            - "{{ .ModelHfID }}"
            - "--revision"
            - "{{ .HfRevision }}"
            - "--bucket"
            - "{{ .S3Bucket }}"
            - "--prefix"
            - "models/{{ .ModelPath }}"
          env:
{{- if .HfToken }}
            - name: HF_TOKEN
              value: "{{ .HfToken }}"
{{- end }}
            - name: AWS_REGION
              value: "{{ .AWSRegion }}"
          resources:
            requests:
              cpu: "500m"
              memory: "512Mi"
              ephemeral-storage: "1Gi"
            limits:
              cpu: "2"
              memory: "2Gi"
              ephemeral-storage: "5Gi"
